{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "composite": true,
    "paths": {
      "@innovation-os/shared/*": ["../shared/src/*"],
      "@innovation-os/foundation/*": ["../foundation/src/*"],
      "@innovation-os/domain/*": ["../domain/src/*"]
    }
  },
  "references": [
    { "path": "../shared" },
    { "path": "../foundation" },
    { "path": "../domain" }
  ],
  "include": ["src/**/*"]
}
